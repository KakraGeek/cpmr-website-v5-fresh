---
/**
 * E4-S07 — Awards & Recognition (`T_GENERIC_CONTENT`; UX Blueprint §8.2 list with date + awarding body).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../layout/SiteHeader.astro';
import SiteFooter from '../layout/SiteFooter.astro';
import Breadcrumbs from '../layout/Breadcrumbs.astro';
import AboutHubSideNav from './about/AboutHubSideNav.astro';
import AboutHubInThisSection from './about/AboutHubInThisSection.astro';
import ButtonLink from '../ui/ButtonLink.astro';
import { getAboutHubData } from '../../data/about-hub';
import type { AwardEntry, AwardsPageData } from './awards-page-data';

interface Props {
	page: AwardsPageData;
	pathname: string;
	seoCanonicalPath: string;
}

const { page, pathname, seoCanonicalPath } = Astro.props;

const hub = getAboutHubData();

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: hub.pageTitle, href: '/about/' },
	{ label: page.title },
];

function formatAwardDate(date: string): string {
	const trimmed = date.trim();
	const parsed = Date.parse(trimmed);
	if (!Number.isNaN(parsed) && /^\d{4}-\d{2}-\d{2}/.test(trimmed)) {
		return new Intl.DateTimeFormat('en-GB', {
			day: 'numeric',
			month: 'long',
			year: 'numeric',
			timeZone: 'UTC',
		}).format(new Date(trimmed));
	}
	return trimmed;
}

function sortAwards(awards: AwardEntry[]): AwardEntry[] {
	return [...awards].sort((a, b) => {
		const pa = Date.parse(a.date);
		const pb = Date.parse(b.date);
		if (!Number.isNaN(pa) && !Number.isNaN(pb)) return pb - pa;
		return b.date.localeCompare(a.date);
	});
}

const awards = sortAwards(page.awards ?? []);
---

<BaseLayout title={page.seoTitle} description={page.seoDescription} seoCanonicalPath={seoCanonicalPath}>
	<SiteHeader slot="header" currentPath={pathname} />
	<div class="border-b border-border-subtle bg-surface-page">
		<div class="mx-auto w-full max-w-content px-4 py-6">
			<Breadcrumbs items={breadcrumbItems} />
		</div>
	</div>
	<AboutHubInThisSection
		groups={hub.navGroups}
		pathname={pathname}
		label={hub.inThisSectionLabel}
	/>
	<article class="bg-surface-page">
		<div class="mx-auto w-full max-w-content px-4 py-8 md:py-10">
			<div class="lg:grid lg:grid-cols-[minmax(12rem,16rem)_minmax(0,1fr)] lg:gap-10 xl:gap-12">
				<AboutHubSideNav
					groups={hub.navGroups}
					pathname={pathname}
					heading={hub.inThisSectionLabel}
				/>
				<div class="min-w-0">
					{
						page.eyebrow ? (
							<p class="font-sans text-sm font-semibold uppercase tracking-wide text-text-secondary">
								{page.eyebrow}
							</p>
						) : null
					}
					<h1
						class:list={[
							'font-serif text-3xl font-bold tracking-tight text-text-primary md:text-4xl',
							page.eyebrow ? 'mt-2' : '',
						]}
					>
						{page.title}
					</h1>
					{
						page.lede ? (
							<p class="mt-4 max-w-prose font-sans text-lg leading-relaxed text-text-secondary">
								{page.lede}
							</p>
						) : null
					}
					{
						awards.length > 0 ? (
							<ul class="mt-8 space-y-6" role="list" aria-label="Awards and recognition">
								{awards.map((award) => {
									const body = award.awardingBody?.trim();
									return (
										<li class="rounded-lg border border-border-subtle bg-surface-card p-5 md:p-6">
											<article aria-labelledby={`award-${award.id}-title`}>
												<h2
													id={`award-${award.id}-title`}
													class="font-serif text-xl font-bold tracking-tight text-text-primary md:text-2xl"
												>
													{award.title}
												</h2>
												<dl class="mt-3 space-y-1 font-sans text-sm text-text-secondary">
													<div class="flex flex-wrap gap-x-2">
														<dt class="font-semibold text-text-primary">Date</dt>
														<dd>{formatAwardDate(award.date)}</dd>
													</div>
													{
														body ? (
															<div class="flex flex-wrap gap-x-2">
																<dt class="font-semibold text-text-primary">Awarding body</dt>
																<dd>{body}</dd>
															</div>
														) : null
													}
												</dl>
												{
													award.summary?.trim() ? (
														<p class="mt-3 max-w-prose font-sans text-base leading-relaxed text-text-secondary">
															{award.summary}
														</p>
													) : null
												}
											</article>
										</li>
									);
								})}
							</ul>
						) : (
							<p class="mt-8 font-sans text-base text-text-secondary">
								No awards are published yet. Check back after institutional verification.
							</p>
						)
					}
					{
						page.relatedLink ? (
							<p class="mt-8 max-w-prose">
								<ButtonLink
									href={page.relatedLink.href}
									label={page.relatedLink.label}
									variant="secondary"
								/>
							</p>
						) : null
					}
				</div>
			</div>
		</div>
	</article>
	<SiteFooter slot="footer" currentPath={pathname} />
</BaseLayout>
