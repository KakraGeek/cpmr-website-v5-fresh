---
/**
 * E3-S03 — Homepage announcements strip (DESIGN.md §13.9 `AnnouncementBand`, UX Blueprint §7 H3).
 * Interim data: `src/content/home/announcements-strip.json`. E8-S01 may swap the loader to the
 * `announcements` collection while preserving the prop shape consumed here.
 */
import ButtonLink from '../ui/ButtonLink.astro';

export type AnnouncementPriority = 'info' | 'warning' | 'critical';

/** One row in the strip; stable keys for E8-S01 rewiring. */
export type AnnouncementStripItem = {
	id?: string;
	priority: AnnouncementPriority;
	headline: string;
	message: string;
	link?: { label: string; href: string };
	editorial_status?: 'draft' | 'in_review' | 'approved' | 'archived';
	content_owner_role?: 'super_admin' | 'content_admin';
	last_reviewed?: string;
	last_updated?: string;
};

/** Document envelope mirrors settings editorial fields (governed home content). */
export type HomeAnnouncementsStripData = {
	editorial_status: 'draft' | 'in_review' | 'approved' | 'archived';
	content_owner_role?: 'super_admin' | 'content_admin';
	last_reviewed?: string;
	last_updated?: string;
	section_title: string;
	items: AnnouncementStripItem[];
};

interface Props {
	data: HomeAnnouncementsStripData;
}

const { data } = Astro.props;

const stripApproved = data.editorial_status === 'approved';
const items = stripApproved
	? data.items
			.filter((item) => !item.editorial_status || item.editorial_status === 'approved')
			.slice(0, 2)
	: [];

const priorityBorder: Record<AnnouncementPriority, string> = {
	info: 'border-l-[var(--color-info-fg)]',
	warning: 'border-l-[var(--color-warning-fg)]',
	critical: 'border-l-[var(--color-danger-fg)]',
};

const priorityLabel: Record<AnnouncementPriority, string> = {
	info: 'info',
	warning: 'warning',
	critical: 'critical',
};
---

{
	items.length > 0 ? (
		<aside
			class="w-full border-y border-neutral-800 bg-neutral-950 text-neutral-50"
			aria-labelledby="home-announcements-heading"
			role="region"
		>
			<div class="mx-auto w-full max-w-content px-4 py-4 md:py-5">
				<h2
					id="home-announcements-heading"
					class="font-sans text-xs font-semibold uppercase tracking-wider text-neutral-400"
				>
					{data.section_title}
				</h2>
				<ul class="mt-4 grid list-none gap-4 p-0 md:grid-cols-2 md:gap-6">
					{items.map((item) => (
						<li class="min-w-0">
							<article
								class:list={[
									'rounded-md border border-neutral-800 border-l-4 bg-neutral-900/80 pl-4 pr-3 py-3',
									priorityBorder[item.priority],
								]}
							>
								<p class="sr-only">Priority: {priorityLabel[item.priority]}</p>
								<h3 class="font-serif text-base font-semibold leading-snug text-neutral-50 md:text-lg">
									{item.headline}
								</h3>
								<p class="mt-1 font-sans text-sm leading-relaxed text-neutral-200">{item.message}</p>
								{item.link ? (
									<div class="mt-3">
										<ButtonLink
											href={item.link.href}
											label={item.link.label}
											variant="ghost"
											size="sm"
											external={
												item.link.href.startsWith('http://') ||
												item.link.href.startsWith('https://')
											}
											class="!text-brand-200 hover:!text-brand-100 hover:!bg-white/10"
										/>
									</div>
								) : null}
							</article>
						</li>
					))}
				</ul>
			</div>
		</aside>
	) : null
}
