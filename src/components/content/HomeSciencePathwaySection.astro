---
/**
 * E3-S05 — Single homepage pathway band (PRD/blueprint modules H5 or H6): one hub card plus
 * optional preview cards or an honest empty state (no fabricated collection rows).
 */
export type PathwayHubCard = {
	title: string;
	description?: string;
	href: string;
};

export type PathwayPreviewCard = {
	title: string;
	description?: string;
	href: string;
};

export type PathwayEmptyState = {
	title: string;
	body: string;
};

export type PathwaySectionContent = {
	eyebrow?: string;
	title: string;
	lede?: string;
	hub_card: PathwayHubCard;
	preview_cards: PathwayPreviewCard[];
	empty_state: PathwayEmptyState;
};

interface Props {
	section: PathwaySectionContent;
	headingId: string;
	surface: 'page' | 'sunken';
	/** Decorative icon key for the hub tile */
	hubVisual: 'research' | 'departments';
}

const { section, headingId, surface, hubVisual } = Astro.props;

const surfaceClass = surface === 'page' ? 'bg-surface-page' : 'bg-surface-sunken';

const hubExternal =
	section.hub_card.href.startsWith('http://') || section.hub_card.href.startsWith('https://');
const hubAria = hubExternal ? `${section.hub_card.title} (opens external site)` : undefined;

const iconClass = 'size-md shrink-0 text-brand-700';
---

<section
	class:list={['border-t border-border-subtle', surfaceClass]}
	aria-labelledby={headingId}
>
	<div class="mx-auto w-full max-w-content px-4 py-10 md:py-12">
		{
			section.eyebrow ? (
				<p class="font-sans text-sm font-semibold uppercase tracking-wide text-text-secondary">
					{section.eyebrow}
				</p>
			) : null
		}
		<h2
			id={headingId}
			class:list={[
				'font-serif text-2xl font-bold tracking-tight text-text-primary md:text-3xl',
				section.eyebrow ? 'mt-2' : '',
			]}
		>
			{section.title}
		</h2>
		{
			section.lede ? (
				<p class="mt-4 max-w-3xl font-sans text-base leading-relaxed text-text-secondary">
					{section.lede}
				</p>
			) : null
		}

		<div
			class="mt-8 flex flex-col gap-6 lg:flex-row lg:items-stretch lg:gap-8"
		>
			<a
				href={section.hub_card.href}
				rel={hubExternal ? 'noopener noreferrer' : undefined}
				target={hubExternal ? '_blank' : undefined}
				aria-label={hubAria}
				class:list={[
					'group relative flex min-h-[11rem] flex-1 flex-col justify-between rounded-lg border border-border-subtle bg-surface-card p-6 shadow-e0 transition-shadow duration-base ease-standard',
					'hover:z-raised hover:shadow-e2 focus-visible:relative focus-visible:z-raised focus-visible:outline-none focus-visible:shadow-ring-focus',
					'lg:max-w-md',
				]}
			>
				<div class="flex items-start gap-3">
					{
						hubVisual === 'research' ? (
							<svg class={iconClass} viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<path
									d="M9 3h6v3H9V3ZM7 8h10v12a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2V8Zm5 4v4m-2-2h4"
									stroke="currentColor"
									stroke-width="1.75"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
							</svg>
						) : (
							<svg class={iconClass} viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<path
									d="M4 21V8l8-5 8 5v13M9 21v-8h6v8"
									stroke="currentColor"
									stroke-width="1.75"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
							</svg>
						)
					}
					<div class="min-w-0 flex-1">
						<h3 class="font-sans text-lg font-semibold leading-snug text-text-primary">
							{section.hub_card.title}
						</h3>
						{
							section.hub_card.description ? (
								<p class="mt-2 font-sans text-sm leading-relaxed text-text-secondary">
									{section.hub_card.description}
								</p>
							) : null
						}
					</div>
				</div>
				<span class="mt-6 inline-flex items-center gap-2 font-sans text-sm font-semibold text-brand-700">
					<span>Continue</span>
					<svg
						class="size-sm transition-transform duration-base ease-standard group-hover:translate-x-0.5"
						viewBox="0 0 16 16"
						fill="none"
						aria-hidden="true"
					>
						<path
							d="M6 3h7v7M13 3 3 13"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				</span>
			</a>

			<div class="min-w-0 flex-1">
				{
					section.preview_cards.length > 0 ? (
						<ul class="grid list-none gap-4 p-0 sm:grid-cols-2">
							{section.preview_cards.map((card) => {
								const ext =
									card.href.startsWith('http://') || card.href.startsWith('https://');
								const aria = ext ? `${card.title} (opens external site)` : undefined;
								return (
									<li class="min-w-0">
										<a
											href={card.href}
											rel={ext ? 'noopener noreferrer' : undefined}
											target={ext ? '_blank' : undefined}
											aria-label={aria}
											class="group flex h-full min-h-[8rem] flex-col rounded-lg border border-border-subtle bg-surface-card p-5 shadow-e0 transition-shadow duration-base ease-standard hover:shadow-e2 focus-visible:outline-none focus-visible:shadow-ring-focus"
										>
											<h4 class="font-sans text-base font-semibold text-text-primary">
												{card.title}
											</h4>
											{card.description ? (
												<p class="mt-2 flex-1 font-sans text-sm leading-relaxed text-text-secondary">
													{card.description}
												</p>
											) : null}
										</a>
									</li>
								);
							})}
						</ul>
					) : (
						<div
							role="status"
							class="flex h-full min-h-[11rem] flex-col rounded-lg border border-dashed border-border-subtle bg-surface-card/60 p-5"
						>
							<p class="font-sans text-sm font-semibold text-text-primary">
								{section.empty_state.title}
							</p>
							<p class="mt-3 font-sans text-sm leading-relaxed text-text-secondary">
								{section.empty_state.body}
							</p>
						</div>
					)
				}
			</div>
		</div>
	</div>
</section>
