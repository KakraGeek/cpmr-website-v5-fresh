---
/**
 * DESIGN.md §13.18 — list row for publications (default | compact).
 */
import ButtonLink from '../ui/ButtonLink.astro';

export type PublicationItemProps = {
	title: string;
	authors: string;
	year: number;
	href: string;
	doiHref?: string;
	externalUrl?: string;
	pdfHref?: string;
	pdfLabel?: string;
	departmentLabel?: string;
	departmentHref?: string;
	excerpt?: string;
	variant?: 'default' | 'compact';
};

const {
	title,
	authors,
	year,
	href,
	doiHref,
	externalUrl,
	pdfHref,
	pdfLabel = 'Download PDF',
	departmentLabel,
	departmentHref,
	excerpt,
	variant = 'default',
} = Astro.props;

const isCompact = variant === 'compact';
const externalTarget = externalUrl?.trim();
const showExternal = Boolean(externalTarget);
const showDoi = Boolean(doiHref) && !showExternal;
const showPdf = Boolean(pdfHref);

const focusRing =
	'focus-visible:relative focus-visible:outline-none focus-visible:shadow-ring-focus';

const titleLinkClass =
	`font-serif text-lg font-bold text-text-primary no-underline hover:text-brand-700 ${focusRing}`;
---

<article
	class:list={[
		'border-b border-border-subtle py-4 last:border-b-0',
		isCompact ? 'py-3' : '',
	]}
>
	<div class="flex flex-col gap-3 sm:flex-row sm:gap-6">
		<p
			class:list={[
				'shrink-0 font-mono text-sm font-medium tabular-nums text-text-muted',
				isCompact ? 'sm:w-12' : 'sm:w-14',
			]}
			aria-hidden="true"
		>
			{year}
		</p>
		<div class="min-w-0 flex-1">
			<h3 class="m-0">
				<a href={href} class={titleLinkClass}>
					{title}
				</a>
			</h3>
			<p class="mt-1 truncate font-sans text-sm text-text-secondary">{authors}</p>
			{
				!isCompact && excerpt ? (
					<p class="mt-2 line-clamp-2 font-sans text-sm leading-relaxed text-text-secondary">
						{excerpt}
					</p>
				) : null
			}
			{
				departmentLabel && departmentHref ? (
					<p class="mt-2 font-sans text-xs text-text-secondary">
						<a
							href={departmentHref}
							class:list={[
								'font-medium text-brand-700 no-underline hover:text-brand-800',
								focusRing,
							]}
						>
							{departmentLabel}
						</a>
					</p>
				) : null
			}
			{
				!isCompact && (showDoi || showExternal || showPdf) ? (
					<div class="mt-3 flex flex-wrap items-center gap-3">
						{
							showDoi && doiHref ? (
								<a
									href={doiHref}
									class:list={[
										'inline-flex min-h-11 items-center font-mono text-xs font-medium text-brand-700 no-underline hover:text-brand-800',
										focusRing,
									]}
									rel="noopener noreferrer"
									target="_blank"
								>
									DOI
									<span class="sr-only"> (opens external site)</span>
								</a>
							) : null
						}
						{
							showExternal && externalTarget ? (
								<a
									href={externalTarget}
									class:list={[
										'inline-flex min-h-11 items-center font-sans text-xs font-semibold text-brand-700 no-underline hover:text-brand-800',
										focusRing,
									]}
									rel="noopener noreferrer"
									target="_blank"
								>
									External link
									<span class="sr-only"> (opens external site)</span>
								</a>
							) : null
						}
						{
							showPdf && pdfHref ? (
								<ButtonLink
									href={pdfHref}
									label={pdfLabel}
									variant="ghost"
									size="sm"
									external
								/>
							) : null
						}
					</div>
				) : null
			}
		</div>
	</div>
</article>
