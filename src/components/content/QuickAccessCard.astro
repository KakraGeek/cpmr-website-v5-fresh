---
/**
 * DESIGN.md §13.8 `QuickAccessCard` — whole tile is one focusable `<a>` (keyboard operable).
 * Icons are inline SVG (no Lucide package in this repo).
 */
interface Props {
	label: string;
	href: string;
	icon: 'clinic' | 'dau' | 'departments' | 'publications' | 'products' | 'contact';
	helper?: string;
	tone?: 'neutral' | 'brand';
}

const { label, href, icon, helper, tone = 'neutral' } = Astro.props;

const external = href.startsWith('http://') || href.startsWith('https://');
const ariaLabel = external ? `${label} (opens external site)` : undefined;

const surface =
	tone === 'brand'
		? 'bg-brand-50 border-border-subtle'
		: 'bg-surface-card border-border-subtle';

const iconClass = 'size-md shrink-0 text-brand-700';
---

<a
		class:list={[
		'group relative flex min-h-[3rem] flex-col gap-2 rounded-lg border p-6 shadow-e0 transition-shadow duration-base ease-standard',
		surface,
		'hover:z-raised hover:shadow-e2 focus-visible:relative focus-visible:z-raised focus-visible:outline-none focus-visible:shadow-ring-focus',
	]}
	href={href}
	rel={external ? 'noopener noreferrer' : undefined}
	target={external ? '_blank' : undefined}
	aria-label={ariaLabel}
>
	<div class="flex items-start justify-between gap-3">
		<div class="flex min-w-0 flex-1 items-start gap-3">
			{
				icon === 'clinic' ? (
					<svg class={iconClass} viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="M4 20V10a2 2 0 0 1 2-2h2V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v4h2a2 2 0 0 1 2 2v10M8 12h4m-2-2v4"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				) : icon === 'dau' ? (
					<svg class={iconClass} viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="M9 3h6v4H9V3Zm-4 7h14v11a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V10Zm4 4h6M12 14v4"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				) : icon === 'departments' ? (
					<svg class={iconClass} viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="M4 21V8l8-5 8 5v13M9 21v-8h6v8"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				) : icon === 'publications' ? (
					<svg class={iconClass} viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				) : icon === 'products' ? (
					<svg class={iconClass} viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1ZM8 11l3 8 3-8M12 2v4"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				) : (
					<svg class={iconClass} viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.86.3 1.7.54 2.5a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.58-1.11a2 2 0 0 1 2.11-.45c.8.24 1.64.42 2.5.54A2 2 0 0 1 22 16.92Z"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				)
			}
			<div class="min-w-0 flex-1">
				<h3 class="font-sans text-base font-semibold leading-snug text-text-primary">{label}</h3>
				{
					helper ? (
						<p class="mt-1 font-sans text-sm leading-snug text-text-secondary">{helper}</p>
					) : null
				}
			</div>
		</div>
		<span class="mt-0.5 inline-flex shrink-0 text-text-muted transition-transform duration-base ease-standard group-hover:translate-x-0.5">
			<svg class="size-sm" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<path
					d="M6 3h7v7M13 3 3 13"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</svg>
		</span>
	</div>
</a>
