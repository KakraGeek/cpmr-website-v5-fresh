---
/**
 * E6-S03 — Shared staff profile body (single template for detail routes).
 */
import type { CollectionEntry } from 'astro:content';
import type { DepartmentLink } from './staff-directory-helpers';
import { publicStaffEmail } from './staff-directory-helpers';

type StaffEntry = CollectionEntry<'staff'> & { data: { entry_type: 'staff' } };

interface Props {
	entry: StaffEntry;
	departmentLinks: DepartmentLink[];
}

const { entry, departmentLinks } = Astro.props;
const publicEmail = publicStaffEmail(entry);

const focusRing =
	'focus-visible:relative focus-visible:outline-none focus-visible:shadow-ring-focus';

const sectionHeadingClass =
	'font-serif text-xl font-bold tracking-tight text-text-primary md:text-2xl';
---

<div class="mx-auto w-full max-w-content px-4 py-8 md:py-10">
	{
		entry.data.photo ? (
			<img
				src={entry.data.photo.src}
				alt={entry.data.photo.alt}
				width={entry.data.photo.width}
				height={entry.data.photo.height}
				class="mb-6 h-auto w-full max-w-xs rounded-lg border border-border-subtle object-cover"
				loading="lazy"
				decoding="async"
			/>
		) : null
	}
	<h1 class="font-serif text-3xl font-bold tracking-tight text-text-primary md:text-4xl">
		{entry.data.full_name}
	</h1>
	<p class="mt-2 font-sans text-lg font-medium text-text-secondary">{entry.data.role_title}</p>
	<p class="mt-4 max-w-prose font-sans text-base leading-relaxed text-text-secondary">
		{entry.data.bio_summary}
	</p>

	{
		entry.data.expertise_tags.length > 0 ? (
			<section class="mt-8" aria-labelledby="staff-expertise-heading">
				<h2 id="staff-expertise-heading" class={sectionHeadingClass}>
					Expertise
				</h2>
				<ul
					class="m-0 mt-4 flex flex-wrap gap-2 p-0 list-none"
					role="list"
					aria-label="Areas of expertise"
				>
					{entry.data.expertise_tags.map((tag) => (
						<li>
							<span class="inline-flex rounded-md border border-border-subtle bg-surface-sunken px-3 py-1 font-sans text-sm text-text-secondary">
								{tag}
							</span>
						</li>
					))}
				</ul>
			</section>
		) : null
	}

	<slot />

	{
		departmentLinks.length > 0 ? (
			<section class="mt-10 border-t border-border-subtle pt-10" aria-labelledby="staff-departments-heading">
				<h2 id="staff-departments-heading" class={sectionHeadingClass}>
					Departments
				</h2>
				<ul class="m-0 mt-4 flex flex-wrap gap-3 p-0 list-none" role="list">
					{departmentLinks.map((link) => (
						<li>
							<a
								href={link.href}
								class:list={[
									'inline-flex min-h-11 items-center rounded-md border border-border-subtle bg-surface-card px-4 py-2 font-sans text-sm font-semibold text-brand-700 no-underline transition-colors hover:border-brand-200 hover:bg-surface-sunken',
									focusRing,
								]}
							>
								{link.name}
							</a>
						</li>
					))}
				</ul>
			</section>
		) : null
	}

	{
		publicEmail || entry.data.orcid ? (
			<section class="mt-10" aria-labelledby="staff-contact-heading">
				<h2 id="staff-contact-heading" class={sectionHeadingClass}>
					Contact
				</h2>
				<div class="mt-4 font-sans text-base text-text-secondary">
					{
						publicEmail ? (
							<p>
								<a
									href={`mailto:${publicEmail}`}
									class:list={[
										'font-medium text-brand-700 no-underline hover:text-brand-800',
										focusRing,
									]}
								>
									{publicEmail}
								</a>
							</p>
						) : null
					}
					{
						entry.data.orcid ? (
							<p class:list={[publicEmail ? 'mt-2' : '']}>
								<a
									href={entry.data.orcid}
									class:list={[
										'font-medium text-brand-700 no-underline hover:text-brand-800',
										focusRing,
									]}
									rel="noopener noreferrer"
								>
									ORCID profile
								</a>
							</p>
						) : null
					}
				</div>
			</section>
		) : null
	}
</div>
