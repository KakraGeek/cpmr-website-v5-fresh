---
/**
 * E4-S03 — Vision & Mission at `/about/vision-mission/` (`T_GENERIC_CONTENT` + paired statements).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../layout/SiteHeader.astro';
import SiteFooter from '../layout/SiteFooter.astro';
import Breadcrumbs from '../layout/Breadcrumbs.astro';
import AboutHubSideNav from './about/AboutHubSideNav.astro';
import AboutHubInThisSection from './about/AboutHubInThisSection.astro';
import VisionMissionPaired from './VisionMissionPaired.astro';
import ButtonLink from '../ui/ButtonLink.astro';
import { getAboutHubData } from '../../data/about-hub';
import type { VisionMissionPageData } from './vision-mission-page-data';

interface Props {
	page: VisionMissionPageData;
	pathname: string;
	seoCanonicalPath: string;
}

const { page, pathname, seoCanonicalPath } = Astro.props;

const hub = getAboutHubData();

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: hub.pageTitle, href: '/about/' },
	{ label: page.title },
];
---

<BaseLayout title={page.seoTitle} description={page.seoDescription} seoCanonicalPath={seoCanonicalPath}>
	<SiteHeader slot="header" currentPath={pathname} />
	<div class="border-b border-border-subtle bg-surface-page">
		<div class="mx-auto w-full max-w-content px-4 py-6">
			<Breadcrumbs items={breadcrumbItems} />
		</div>
	</div>
	<AboutHubInThisSection
		groups={hub.navGroups}
		pathname={pathname}
		label={hub.inThisSectionLabel}
	/>
	<article class="bg-surface-page">
		<div class="mx-auto w-full max-w-content px-4 py-8 md:py-10">
			<div class="lg:grid lg:grid-cols-[minmax(12rem,16rem)_minmax(0,1fr)] lg:gap-10 xl:gap-12">
				<AboutHubSideNav
					groups={hub.navGroups}
					pathname={pathname}
					heading={hub.inThisSectionLabel}
				/>
				<div class="min-w-0">
					{
						page.eyebrow ? (
							<p class="font-sans text-sm font-semibold uppercase tracking-wide text-text-secondary">
								{page.eyebrow}
							</p>
						) : null
					}
					<h1
						class:list={[
							'font-serif text-3xl font-bold tracking-tight text-text-primary md:text-4xl',
							page.eyebrow ? 'mt-2' : '',
						]}
					>
						{page.title}
					</h1>
					{
						page.lede ? (
							<p class="mt-4 max-w-prose font-sans text-lg leading-relaxed text-text-secondary">
								{page.lede}
							</p>
						) : null
					}
					<VisionMissionPaired vision={page.vision} mission={page.mission} />
					{
						page.relatedLink ? (
							<p class="mt-8 max-w-prose">
								<ButtonLink
									href={page.relatedLink.href}
									label={page.relatedLink.label}
									variant="secondary"
								/>
							</p>
						) : null
					}
				</div>
			</div>
		</div>
	</article>
	<SiteFooter slot="footer" currentPath={pathname} />
</BaseLayout>
