---
/**
 * Native &lt;button&gt; — token contract aligned with DESIGN.md §13.23 for form actions.
 * Copy via default slot or `label` prop from caller only (CMS/content layer).
 */
interface Props {
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'ghost' | 'link';
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
  label?: string;
  class?: string;
}

const {
  type = 'button',
  variant = 'primary',
  size = 'md',
  fullWidth = false,
  label,
  class: className = '',
} = Astro.props;

const baseFocus =
  'focus-visible:outline-none focus-visible:shadow-ring-focus focus-visible:relative';

const width = fullWidth ? 'w-full justify-center' : '';

const sizeClasses: Record<NonNullable<Props['size']>, string> = {
  sm: 'rounded-md py-2 px-3 text-sm gap-2',
  md: 'rounded-md py-3 px-5 text-sm gap-2',
  lg: 'rounded-md py-4 px-6 text-base gap-2',
};

const variantClasses: Record<NonNullable<Props['variant']>, string> = {
  primary:
    'bg-brand-600 text-text-on-brand shadow-e1 hover:bg-brand-700 active:bg-brand-700 ' + baseFocus,
  secondary:
    'border border-border-brand bg-surface-card text-text-link shadow-e0 hover:bg-brand-50 ' +
    baseFocus,
  ghost: 'bg-transparent text-text-link shadow-e0 hover:bg-brand-50 ' + baseFocus,
  link:
    'inline min-h-0 rounded-none bg-transparent p-0 text-text-link underline shadow-e0 hover:text-text-link-hover ' +
    baseFocus,
};

const layout =
  variant === 'link' ? 'inline-flex items-center gap-2' : 'inline-flex items-center gap-2 font-sans';
---

<button
  type={type}
  class:list={[
    layout,
    variantClasses[variant],
    variant !== 'link' ? sizeClasses[size] : '',
    width,
    className,
  ]}
>
  {Astro.slots.has('icon-leading') ? <slot name="icon-leading" /> : null}
  {
    Astro.slots.has('default') ? (
      <span class:list={[variant === 'link' ? '' : 'text-left']}>
        <slot />
      </span>
    ) : label ? (
      <span class:list={[variant === 'link' ? '' : 'text-left']}>{label}</span>
    ) : null
  }
  {Astro.slots.has('icon-trailing') ? <slot name="icon-trailing" /> : null}
</button>
