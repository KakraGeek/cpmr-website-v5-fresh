---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'CPMR Website Rebuild' } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		{/*
		  E1-S03 Typography loading — Inter + Source Serif 4 per DESIGN.md §4.1 font stacks.
		  - Preconnect warms the TLS handshake to Google Fonts hosts before the stylesheet request fires.
		  - `display=swap` keeps text visible immediately via the system fallbacks declared in
		    @theme (--font-sans / --font-serif), avoiding FOIT and limiting CLS to small metric shifts.
		  - Latin subset only; weights map to DESIGN.md §1 font_weight tokens (400, 500, 600, 700).
		  - Source Serif 4 is loaded only at weights actually used by headings (DESIGN.md §4.2 h1.hero,
		    h1.page) plus italic 400 for occasional editorial emphasis on serif heroes.
		  - Fonts are presentation infrastructure; no editorial content lives here (CMS-ready).
		  - Architecture cross-ref: docs/03_architecture/04_architecture.md §14 (font-display + subsetting).
		*/}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&display=swap"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-full antialiased">
		<slot />
	</body>
</html>
