---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — CPMR Website Rebuild">
	<main class="flex min-h-screen flex-col items-center justify-center gap-6 p-6 text-center">
		<p class="text-sm font-medium uppercase tracking-wide text-neutral-600">404</p>
		<h1 class="text-3xl font-bold text-neutral-900">Page not found</h1>
		<p class="max-w-md text-base text-neutral-700">
			The page you are looking for does not exist or may have been moved.
		</p>
		<p>
			<a
				href="/"
				class="inline-flex rounded-md bg-neutral-900 px-4 py-2 text-sm font-semibold text-white hover:bg-neutral-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-900 focus-visible:ring-offset-2"
			>
				Back to home
			</a>
		</p>
	</main>
</Layout>
