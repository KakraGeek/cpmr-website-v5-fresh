---
/**
 * E5-S01 — Departments index at `/departments/` (UX Blueprint §10; 05 §4.3).
 * Lists verified, approved departments from `getCollection('departments')`.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/layout/SiteHeader.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import Card from '../../components/ui/Card.astro';

const pathname = Astro.url.pathname;

const allEntries = await getCollection('departments');

const shell = allEntries.find((entry) => entry.data.entry_type === 'index_shell');
if (!shell || shell.data.entry_type !== 'index_shell') {
	throw new Error('E5-S01: expected departments index_shell entry (src/content/departments/index-shell.md)');
}

const isPublicDepartment = (
	entry: (typeof allEntries)[number],
): entry is (typeof allEntries)[number] & {
	data: { entry_type: 'department' };
} => {
	if (entry.data.entry_type !== 'department') return false;
	const { editorial_status, verified } = entry.data;
	return editorial_status === 'approved' && verified === true;
};

const publicDepartments = allEntries.filter(isPublicDepartment).sort((a, b) => {
	const orderA = a.data.sort_order ?? Number.MAX_SAFE_INTEGER;
	const orderB = b.data.sort_order ?? Number.MAX_SAFE_INTEGER;
	if (orderA !== orderB) return orderA - orderB;
	return a.data.name.localeCompare(b.data.name, 'en');
});

const categoryLabels: Record<
	(typeof publicDepartments)[number]['data']['category'],
	string
> = {
	research: 'Research departments',
	service: 'Service departments',
	administrative: 'Administrative departments',
};

const categoryOrder: (typeof publicDepartments)[number]['data']['category'][] = [
	'research',
	'service',
	'administrative',
];

const departmentsByCategory = categoryOrder
	.map((category) => ({
		category,
		label: categoryLabels[category],
		items: publicDepartments.filter((entry) => entry.data.category === category),
	}))
	.filter((group) => group.items.length > 0);

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: shell.data.page_title },
];

const focusRing =
	'focus-visible:relative focus-visible:outline-none focus-visible:shadow-ring-focus';

const cardLinkClass =
	`group block h-full no-underline text-inherit transition-shadow ${focusRing}`;
---

<BaseLayout
	title={shell.data.seo_title}
	description={shell.data.seo_description}
	seoCanonicalPath={shell.data.seo_canonical_path ?? '/departments/'}
>
	<SiteHeader slot="header" currentPath={pathname} />
	<div class="border-b border-border-subtle bg-surface-page">
		<div class="mx-auto w-full max-w-content px-4 py-6">
			<Breadcrumbs items={breadcrumbItems} />
		</div>
	</div>
	<article class="bg-surface-page">
		<div class="mx-auto w-full max-w-content px-4 py-8 md:py-10">
			<h1 class="font-serif text-3xl font-bold tracking-tight text-text-primary md:text-4xl">
				{shell.data.page_title}
			</h1>
			<p class="mt-4 max-w-prose font-sans text-lg leading-relaxed text-text-secondary">
				{shell.data.lede}
			</p>
			<div class="mt-6 max-w-prose font-sans text-base leading-relaxed text-text-secondary [&>p+p]:mt-4">
				{shell.data.intro_paragraphs.map((paragraph) => (
					<p>{paragraph}</p>
				))}
			</div>

			<section class="mt-10 border-t border-border-subtle pt-10" aria-labelledby="departments-list-heading">
				<h2
					id="departments-list-heading"
					class="font-serif text-xl font-bold tracking-tight text-text-primary md:text-2xl"
				>
					{shell.data.listing_section_title}
				</h2>

				{
					publicDepartments.length === 0 ? (
						<div
							class="mt-6 rounded-lg border border-border-subtle bg-surface-sunken p-6"
							role="status"
						>
							<p class="font-sans text-base font-semibold text-text-primary">
								{shell.data.empty_state_title}
							</p>
							<p class="mt-2 max-w-prose font-sans text-sm leading-relaxed text-text-secondary">
								{shell.data.empty_state_body}
							</p>
						</div>
					) : (
						departmentsByCategory.map((group) => (
							<div class="mt-8">
								<h3 class="font-sans text-sm font-semibold uppercase tracking-wide text-text-secondary">
									{group.label}
								</h3>
								<ul
									class="m-0 mt-4 grid list-none gap-4 p-0 sm:grid-cols-2 lg:grid-cols-3"
									role="list"
								>
									{group.items.map((entry) => {
										const href = `/departments/${entry.data.id}/`;
										return (
											<li>
												<Card elevation="hover-lift" padding="5" class="h-full">
													<a href={href} class={cardLinkClass}>
														<p class="font-sans text-xs font-semibold uppercase tracking-wide text-text-secondary">
															{categoryLabels[entry.data.category]}
														</p>
														<h3 class="mt-2 font-sans text-base font-semibold text-text-primary group-hover:text-brand-700">
															{entry.data.name}
														</h3>
														<p class="mt-2 font-sans text-sm leading-relaxed text-text-secondary">
															{entry.data.mandate_summary}
														</p>
														<p class="mt-3 font-sans text-sm font-medium text-brand-700">
															View department
															<span class="sr-only"> — {entry.data.name}</span>
														</p>
													</a>
												</Card>
											</li>
										);
									})}
								</ul>
							</div>
						))
					)
				}
			</section>
		</div>
	</article>
	<SiteFooter slot="footer" currentPath={pathname} />
</BaseLayout>
