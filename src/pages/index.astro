---
/**
 * E3-S01 — Home route: `BaseLayout` + governed hero from `src/content/home/hero.md`.
 * E3-S02 — Quick access grid from `src/content/home/quick-access.md`.
 * E3-S03 — Announcements strip from `src/content/home/announcements-strip.json` (interim; E8-S01 may rewire source).
 * E3-S04 — Mandate snapshot from `src/content/home/mandate-snapshot.json` (DESIGN.md §14.1 `home.mandate`;
 * JSON envelope matches E3-S03 interim pattern until collection schema can include `kind: mandate`).
 * E3-S05 — Research + department preview bands (H5/H6) from `src/content/home/research-department-previews.json`;
 * hub cards target `/research/` and `/departments/`; optional preview rows stay empty until routes/collections exist.
 * E3-S06 — Services + products preview bands (H7/H8) from `src/content/home/services-products-previews.json`;
 * disclaimers and hrefs are governed; empty `href` omits anchors per PRD link policy.
 * E3-S07 — News + events row (H9) from `src/content/home/news-events-row.json`; `newsItems` is filled
 * from `getCollection('news')` once E8-S02 registers the collection and news routes exist (currently []).
 * E3-S08 — Publications / resources teaser (H10) from `src/content/home/publications-resources-teaser.json`;
 * `teaser_focus` switches publications vs priority-download copy; `publicationPreviewItems` fills from
 * `getCollection('publications')` once E6-S04 ships (currently []).
 * E3-S09 — Partners band (H11) from `src/content/home/partners-band.json`; logos from `src/assets/partners/`
 * resolved inside `HomePartnersBand.astro`; outbound policy copy renders when external partner links exist.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import HomeHero from '../components/content/HomeHero.astro';
import HomeAnnouncementsStrip from '../components/content/HomeAnnouncementsStrip.astro';
import HomeMandateSnapshot from '../components/content/HomeMandateSnapshot.astro';
import HomeResearchDepartmentPreviews from '../components/content/HomeResearchDepartmentPreviews.astro';
import HomeServicesProductsPreviews from '../components/content/HomeServicesProductsPreviews.astro';
import HomeNewsEventsRow from '../components/content/HomeNewsEventsRow.astro';
import HomePublicationsResourcesTeaser from '../components/content/HomePublicationsResourcesTeaser.astro';
import HomePartnersBand from '../components/content/HomePartnersBand.astro';
import QuickAccessCard from '../components/content/QuickAccessCard.astro';
import announcementsStrip from '../content/home/announcements-strip.json';
import mandateSnapshot from '../content/home/mandate-snapshot.json';
import researchDepartmentPreviews from '../content/home/research-department-previews.json';
import servicesProductsPreviews from '../content/home/services-products-previews.json';
import newsEventsRow from '../content/home/news-events-row.json';
import publicationsResourcesTeaser from '../content/home/publications-resources-teaser.json';
import partnersBand from '../content/home/partners-band.json';
import { getEntry } from 'astro:content';
import type { HomeAnnouncementsStripData } from '../components/content/HomeAnnouncementsStrip.astro';
import type { HomeMandateSnapshotData } from '../components/content/HomeMandateSnapshot.astro';
import type { HomeResearchDepartmentPreviewsData } from '../components/content/HomeResearchDepartmentPreviews.astro';
import type { HomeServicesProductsPreviewsData } from '../components/content/HomeServicesProductsPreviews.astro';
import type { HomeNewsEventsRowData, HomeNewsEventsRowNewsItem } from '../components/content/HomeNewsEventsRow.astro';
import type {
	HomePublicationsResourcesTeaserData,
	HomePublicationsResourcesTeaserPublicationItem,
} from '../components/content/HomePublicationsResourcesTeaser.astro';
import type { HomePartnersBandData } from '../components/content/HomePartnersBand.astro';

const pathname = Astro.url.pathname;
const heroEntry = await getEntry('home', 'hero');
if (!heroEntry) {
	throw new Error('Missing homepage hero: expected src/content/home/hero.md');
}
if (heroEntry.data.kind !== 'hero') {
	throw new Error('Invalid homepage hero: src/content/home/hero.md must use kind: hero');
}

const quickAccessEntry = await getEntry('home', 'quick-access');
if (!quickAccessEntry) {
	throw new Error('Missing quick access content: expected src/content/home/quick-access.md');
}
if (quickAccessEntry.data.kind !== 'quick_access') {
	throw new Error('Invalid quick access: src/content/home/quick-access.md must use kind: quick_access');
}

const { data: heroData } = heroEntry;
const qa = quickAccessEntry.data;

const stripData = announcementsStrip as HomeAnnouncementsStripData;
const mandateData = mandateSnapshot as HomeMandateSnapshotData;
const researchDeptPreviewsData = researchDepartmentPreviews as HomeResearchDepartmentPreviewsData;
const servicesProductsData = servicesProductsPreviews as HomeServicesProductsPreviewsData;
const newsEventsData = newsEventsRow as HomeNewsEventsRowData;
const publicationsResourcesData = publicationsResourcesTeaser as HomePublicationsResourcesTeaserData;
const partnersBandData = partnersBand as HomePartnersBandData;

/** E8-S02: replace with `getCollection('news')` (sort, slice) once the `news` collection and `/news/` routes ship. */
const newsPreviewItems: HomeNewsEventsRowNewsItem[] = [];

/** E6-S04: replace with sorted slice from `getCollection('publications')` once the publications library collection ships. */
const publicationPreviewItems: HomePublicationsResourcesTeaserPublicationItem[] = [];
---

<BaseLayout>
	<SiteHeader slot="header" currentPath={pathname} />
	<HomeHero data={heroData} />
	<section
		class="border-t border-border-subtle bg-surface-page"
		aria-labelledby="home-quick-access-heading"
	>
		<div class="mx-auto w-full max-w-content px-4 py-10 md:py-12">
			<h2
				id="home-quick-access-heading"
				class="font-serif text-2xl font-bold tracking-tight text-text-primary md:text-3xl"
			>
				{qa.section_title}
			</h2>
			<div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6">
				{qa.tiles.map((tile) => (
					<QuickAccessCard
						label={tile.label}
						href={tile.href}
						helper={tile.helper}
						icon={tile.icon}
						tone={tile.tone}
					/>
				))}
			</div>
		</div>
	</section>
	<HomeAnnouncementsStrip data={stripData} />
	<HomeMandateSnapshot data={mandateData} />
	<HomeResearchDepartmentPreviews data={researchDeptPreviewsData} />
	<HomeServicesProductsPreviews data={servicesProductsData} />
	<HomeNewsEventsRow data={newsEventsData} newsItems={newsPreviewItems} />
	<HomePublicationsResourcesTeaser
		data={publicationsResourcesData}
		publicationItems={publicationPreviewItems}
	/>
	<HomePartnersBand data={partnersBandData} />
	<SiteFooter slot="footer" currentPath={pathname} />
</BaseLayout>
