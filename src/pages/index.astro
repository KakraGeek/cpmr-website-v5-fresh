---
/**
 * E3-S01 — Home route: `BaseLayout` + governed hero from `src/content/home/hero.md`.
 * E3-S02 — Quick access grid from `src/content/home/quick-access.md`.
 * E3-S03 — Announcements strip from `src/content/home/announcements-strip.json` (interim; E8-S01 may rewire source).
 * E3-S04 — Mandate snapshot from `src/content/home/mandate-snapshot.json` (DESIGN.md §14.1 `home.mandate`;
 * JSON envelope matches E3-S03 interim pattern until collection schema can include `kind: mandate`).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import HomeHero from '../components/content/HomeHero.astro';
import HomeAnnouncementsStrip from '../components/content/HomeAnnouncementsStrip.astro';
import HomeMandateSnapshot from '../components/content/HomeMandateSnapshot.astro';
import QuickAccessCard from '../components/content/QuickAccessCard.astro';
import announcementsStrip from '../content/home/announcements-strip.json';
import mandateSnapshot from '../content/home/mandate-snapshot.json';
import { getEntry } from 'astro:content';
import type { HomeAnnouncementsStripData } from '../components/content/HomeAnnouncementsStrip.astro';
import type { HomeMandateSnapshotData } from '../components/content/HomeMandateSnapshot.astro';

const pathname = Astro.url.pathname;
const heroEntry = await getEntry('home', 'hero');
if (!heroEntry) {
	throw new Error('Missing homepage hero: expected src/content/home/hero.md');
}
if (heroEntry.data.kind !== 'hero') {
	throw new Error('Invalid homepage hero: src/content/home/hero.md must use kind: hero');
}

const quickAccessEntry = await getEntry('home', 'quick-access');
if (!quickAccessEntry) {
	throw new Error('Missing quick access content: expected src/content/home/quick-access.md');
}
if (quickAccessEntry.data.kind !== 'quick_access') {
	throw new Error('Invalid quick access: src/content/home/quick-access.md must use kind: quick_access');
}

const { data: heroData } = heroEntry;
const qa = quickAccessEntry.data;

const stripData = announcementsStrip as HomeAnnouncementsStripData;
const mandateData = mandateSnapshot as HomeMandateSnapshotData;
---

<BaseLayout>
	<SiteHeader slot="header" currentPath={pathname} />
	<HomeHero data={heroData} />
	<section
		class="border-t border-border-subtle bg-surface-page"
		aria-labelledby="home-quick-access-heading"
	>
		<div class="mx-auto w-full max-w-content px-4 py-10 md:py-12">
			<h2
				id="home-quick-access-heading"
				class="font-serif text-2xl font-bold tracking-tight text-text-primary md:text-3xl"
			>
				{qa.section_title}
			</h2>
			<div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6">
				{qa.tiles.map((tile) => (
					<QuickAccessCard
						label={tile.label}
						href={tile.href}
						helper={tile.helper}
						icon={tile.icon}
						tone={tile.tone}
					/>
				))}
			</div>
		</div>
	</section>
	<HomeAnnouncementsStrip data={stripData} />
	<HomeMandateSnapshot data={mandateData} />
	<SiteFooter slot="footer" currentPath={pathname} />
</BaseLayout>
